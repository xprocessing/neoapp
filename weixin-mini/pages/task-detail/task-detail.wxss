.container { padding: 0; }
.cover { width: 100%; height: 200px; }
.section { background: #fff; margin: 12px; border-radius: 12px; padding: 16px; }
.title { font-size: 18px; font-weight: bold; }
.price-row { margin-top: 8px; }
.price { color: #f60; font-size: 22px; font-weight: bold; }
.gift { font-size: 12px; color: #999; margin-left: 8px; }
.intro { font-size: 14px; color: #666; margin-top: 8px; }
.content { margin-top: 12px; padding: 12px; background: #f5f5f5; border-radius: 8px; font-size: 14px; }
.expire { font-size: 12px; color: #999; margin-top: 8px; }
.label { font-size: 14px; color: #333; margin-top: 12px; margin-bottom: 4px; }
input { border: 1px solid #e5e5e5; border-radius: 8px; padding: 8px; font-size: 14px; }
.img-row { display: flex; gap: 8px; flex-wrap: wrap; }
.upload-img { width: 80px; height: 80px; border-radius: 8px; }
.upload-btn { width: 80px; height: 80px; border: 2px dashed #ccc; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 30px; color: #ccc; }
.btn-area { padding: 16px; }
.btn { border-radius: 8px; font-size: 15px; margin-top: 12px; }
.btn-primary { background: #0052D9; color: #fff; }
.btn-warn { background: #f60; color: #fff; }
.status { text-align: center; padding: 16px; font-size: 15px; }
.status.warn { color: #f60; }
.status.success { color: #07c160; }
.status.danger { color: #e74c3c; }
