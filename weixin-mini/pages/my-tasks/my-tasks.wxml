<view class="container">
  <view class="header">我的任务</view>
  <view wx:if="{{orders.length===0}}" class="empty">暂无任务</view>
  <view wx:for="{{orders}}" wx:key="id" class="card" bindtap="goDetail" data-id="{{item.taskId}}">
    <view class="row"><text>任务 #{{item.taskId}}</text><text class="tag tag-{{item.auditStatus}}">{{statusText[item.auditStatus]}}</text></view>
    <view class="row"><text>奖励：</text><text class="price">¥{{item.rewardAmount}}</text></view>
    <view wx:if="{{item.submitNote}}" class="row"><text>备注：{{item.submitNote}}</text></view>
    <view wx:if="{{item.auditNote}}" class="row"><text class="audit-{{item.auditStatus===4?'danger':'success'}}">审核：{{item.auditNote}}</text></view>
    <view class="actions">
      <button wx:if="{{item.auditStatus===3&&item.grantPay===1&&item.withdrawStatus===0}}" class="btn" bindtap="withdraw" data-id="{{item.id}}" size="mini">领取奖励</button>
      <text wx:if="{{item.withdrawStatus===1}}" class="status warn">提现处理中</text>
      <text wx:if="{{item.withdrawStatus===2}}" class="status success">已到账</text>
    </view>
  </view>
</view>
