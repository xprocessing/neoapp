<view class="container">
  <view class="header">任务中心</view>

  <view wx:if="{{tasks.length===0}}" class="empty">暂无上架任务</view>

  <view wx:for="{{tasks}}" wx:key="id" class="task-card" bindtap="goDetail" data-id="{{item.id}}">
    <image wx:if="{{item.taskCover}}" src="{{item.taskCover}}" class="task-cover" mode="aspectFill" />
    <view class="task-body">
      <view class="task-title">{{item.taskTitle}}</view>
      <view class="task-intro">{{item.taskIntro}}</view>
      <view class="task-footer">
        <text class="task-price">¥{{item.rewardAmount}}</text>
        <text class="task-gift">{{item.gift || '无赠品'}}</text>
        <text class="task-claim-btn" catchtap="doClaim" data-id="{{item.id}}">{{claimedIds[item.id] ? '已领取' : '领取'}}</text>
      </view>
    </view>
  </view>
</view>
