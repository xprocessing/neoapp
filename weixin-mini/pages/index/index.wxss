.container { padding: 16px; }
.header { font-size: 20px; font-weight: bold; margin-bottom: 16px; color: #1a1a1a; }
.empty { text-align: center; padding: 80px 0; color: #999; font-size: 14px; }
.task-card { background: #fff; border-radius: 12px; margin-bottom: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.05); }
.task-cover { width: 100%; height: 160px; }
.task-body { padding: 12px; }
.task-title { font-size: 16px; font-weight: 600; color: #1a1a1a; }
.task-intro { font-size: 13px; color: #999; margin-top: 4px; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
.task-footer { display: flex; align-items: center; margin-top: 10px; }
.task-price { color: #f60; font-size: 17px; font-weight: bold; }
.task-gift { font-size: 12px; color: #999; margin-left: 8px; flex: 1; }
.task-claim-btn { background: #0052D9; color: #fff; font-size: 13px; padding: 4px 12px; border-radius: 20px; }
